#!/bin/sh

remote_url="$2"

# Verifica se a URL contém "Minha-conta-GestaoSEI" (seu privado)
case "$remote_url" in
    *Minha-conta-GestaoSEI*)
        exit 0
        ;;
esac

# Verifica se a URL contém "GestaoSEI" (o público)
case "$remote_url" in
    *GestaoSEI*)
        echo ""
        echo "--- AVISO DE SEGURANÇA ---"
        echo "Você está enviando código para o repositório PÚBLICO da organização."
        echo "Certifique-se de que não há dados sensíveis (senhas, nomes reais) no código."
        echo "---"
        exit 0
        ;;
esac

exit 0
